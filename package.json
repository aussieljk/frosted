{
  "name": "frosted-monorepo",
  "version": "0.0.1-canary.153",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "csstype": "3.1.3",
    "@types/minimatch": "5.1.2",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.10",
    "ts-api-utils": {
      "typescript": "^5.9.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "build:storybook": "turbo run build-storybook",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "eslint-config-custom": "workspace:*",
    "prettier": "latest",
    "turbo": "^2.10.5",
    "@changesets/cli": "^2.31.1"
  },
  "engines": {
    "node": "22.x",
    "bun": ">=1.2"
  },
  "packageManager": "bun@1.3.11"
}
