{
  "name": "@frosted-ui/react-native",
  "version": "0.0.0",
  "private": false,
  "main": "expo-router/entry",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./llm-docs": "./docs/llm/README.md",
    "./llm-docs/*": "./docs/llm/*"
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist",
    "docs/llm"
  ],
  "peerDependencies": {
    "lucide-react-native": ">=0.300.0",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-screens": ">=3.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "scripts": {
    "dev": "expo start -c",
    "android": "expo start -c --android",
    "ios": "expo start -c --ios",
    "web": "expo start -c --web",
    "build": "bun run clean:dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "clean": "rm -rf .expo node_modules",
    "clean:dist": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@frosted-ui/colors": "0.0.1-canary.153",
    "@rn-primitives/accordion": "^1.5.2",
    "@rn-primitives/alert-dialog": "^1.5.2",
    "@rn-primitives/aspect-ratio": "^1.5.2",
    "@rn-primitives/avatar": "^1.5.2",
    "@rn-primitives/checkbox": "^1.5.2",
    "@rn-primitives/collapsible": "^1.5.2",
    "@rn-primitives/context-menu": "^1.5.2",
    "@rn-primitives/dialog": "^1.5.2",
    "@rn-primitives/dropdown-menu": "^1.5.2",
    "@rn-primitives/hover-card": "^1.5.2",
    "@rn-primitives/label": "^1.5.2",
    "@rn-primitives/menubar": "^1.5.2",
    "@rn-primitives/popover": "^1.5.2",
    "@rn-primitives/portal": "~1.5.2",
    "@rn-primitives/progress": "^1.5.2",
    "@rn-primitives/radio-group": "^1.5.2",
    "@rn-primitives/select": "^1.5.2",
    "@rn-primitives/separator": "^1.5.2",
    "@rn-primitives/slider": "^1.5.2",
    "@rn-primitives/slot": "^1.5.2",
    "@rn-primitives/switch": "^1.5.2",
    "@rn-primitives/tabs": "^1.5.2",
    "@rn-primitives/toggle": "^1.5.2",
    "@rn-primitives/toggle-group": "^1.5.2",
    "@rn-primitives/tooltip": "^1.5.2",
    "@rn-primitives/types": "^1.5.2"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@types/react": "~19.2.17",
    "expo": "^57.0.7",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "lucide-react-native": "^1.25.0",
    "prettier": "^3.9.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~3.1.0",
    "react-native-reanimated": "~4.5.2",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.26.2",
    "react-native-svg": "15.15.5",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.11.1",
    "tsc-alias": "^1.9.1",
    "typescript": "~7.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/whopio/frosted-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/whopio/frosted-ui.git"
  },
  "bugs": {
    "url": "https://github.com/whopio/frosted-ui/issues"
  }
}
