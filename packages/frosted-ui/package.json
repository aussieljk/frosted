{
  "name": "@aussieljk/frosted",
  "version": "0.0.1",
  "type": "commonjs",
  "description": "Frosted UI design system (fork of whopio/frosted-ui)",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "style": "./styles.css",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": {
      "import": "./styles.css",
      "require": "./styles.css",
      "default": "./styles.css"
    },
    "./styles.lite.css": {
      "import": "./styles.lite.css",
      "require": "./styles.lite.css",
      "default": "./styles.lite.css"
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**",
    "styles.css",
    "styles.lite.css"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:css",
    "build:js": "tsdown --config tsdown.config.mts && node scripts/fix-namespace-exports.mjs",
    "build:css": "postcss src/styles/index.css -o styles.css && node scripts/build-lite-css.js src/styles/index.css -o styles.lite.css",
    "dev": "bun run dev:js & bun run dev:css",
    "dev:js": "tsdown --watch",
    "dev:css": "postcss src/styles/index.css -o styles.css --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "bun run lint:js && bun run lint:css",
    "lint:js": "eslint \"src/**/*.ts*\"",
    "lint:css": "stylelint \"src/**/*.css\"",
    "generate:emoji-colors": "tsx scripts/emoji-colors/generate.ts",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist && rm -rf styles.css && rm -rf styles.lite.css",
    "prepublishOnly": "bun run lint && bun run build",
    "storybook": "bun run dev:css & storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@internationalized/date": "^3.12.2",
    "@react-aria/calendar": "^3.10.1",
    "@react-aria/datepicker": "^3.17.1",
    "@react-aria/focus": "^3.22.1",
    "@react-aria/i18n": "^3.13.1",
    "@react-aria/utils": "^3.34.1",
    "@react-stately/calendar": "^3.10.1",
    "@react-stately/datepicker": "^3.17.1",
    "classnames": "^2.5.1",
    "credit-card-type": "^10.3.0",
    "react-aria-components": "^1.19.0",
    "tailwindcss": "^4.3.3",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "react": "^16.8 || ^17.0 || ^18.0 || ^19.0",
    "react-dom": "^16.8 || ^17.0 || ^18.0 || ^19.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@frosted-ui/colors": "workspace:*",
    "@frosted-ui/icons": "workspace:*",
    "@napi-rs/canvas": "^1.0.2",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-links": "^10.5.3",
    "@storybook/react": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/color-convert": "^3.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.4",
    "color-convert": "^3.1.3",
    "emoji-datasource": "^16.0.0",
    "eslint": "^10.7.0",
    "eslint-config-custom": "workspace:*",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "node-vibrant": "^4.0.4",
    "postcss": "^8.5.21",
    "postcss-cli": "^11.0.1",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-custom-media": "^12.0.1",
    "postcss-discard-empty": "^8.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "storybook": "^10.5.3",
    "stylelint": "^17.14.1",
    "tsdown": "^0.22.12",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/aussieljk/frosted",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aussieljk/frosted.git"
  },
  "bugs": {
    "url": "https://github.com/aussieljk/frosted/issues"
  },
  "engines": {
    "node": ">=20"
  }
}
