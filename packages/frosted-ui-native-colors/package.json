{
  "name": "frosted-ui-native-colors",
  "description": "Generating SwiftUI and Kotlin color assets from Radix Colors",
  "private": false,
  "version": "0.0.1",
  "main": "index.js",
  "module": "index.mjs",
  "types": "types/index.d.ts",
  "scripts": {
    "build": "bun run clean && bun run generate-colors && cd ./colors && zip -r ../frosted-ui-swift-colors.zip ./",
    "generate-colors": "node ./scripts/generate-colors.js",
    "prepublishOnly": "bun run build",
    "postpublish": "bun run clean",
    "clean": "rimraf colors"
  },
  "keywords": [
    "frosted-ui",
    "colors"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whopio/frosted-ui.git"
  },
  "homepage": "https://github.com/whopio/frosted-ui",
  "bugs": {
    "url": "https://github.com/whopio/frosted-ui/issues"
  },
  "devDependencies": {
    "@frosted-ui/colors": "workspace:*",
    "@types/node": "^26.1.1",
    "rimraf": "^6.1.3",
    "tslib": "^2.8.1",
    "typescript": "^7.0.2"
  },
  "license": "MIT"
}
