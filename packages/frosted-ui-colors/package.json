{
  "name": "@frosted-ui/colors",
  "private": false,
  "version": "0.0.0",
  "license": "MIT",
  "description": "Frosted UI Colors",
  "main": "index.js",
  "module": "index.mjs",
  "types": "types/index.d.ts",
  "scripts": {
    "build": "bun run clean && bun run rollup -c && bun run build-css-modules",
    "build-css-modules": "node ./scripts/build-css-modules.js",
    "clean": "rm -f *.css index.js index.mjs"
  },
  "keywords": [
    "frosted-ui",
    "colors"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whopio/frosted-ui.git"
  },
  "homepage": "https://github.com/whopio/frosted-ui",
  "bugs": {
    "url": "https://github.com/whopio/frosted-ui/issues"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^8.2.1",
    "@types/node": "^15.0.3",
    "rollup": "^2.48.0",
    "tslib": "^2.2.0",
    "typescript": "^4.2.4"
  }
}
